# ------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/


# ------------------------------------------------------------
# IDEs — SPYDER
# ------------------------------------------------------------
.spyderproject.db
.spyproject/
.spyderworkspace


# ------------------------------------------------------------
# IDEs — JUPYTER LAB
# ------------------------------------------------------------
.jupyter/
.local/


# ------------------------------------------------------------
# IDEs — ECLIPSE
# ------------------------------------------------------------
.project
.pydevproject
.settings/
.classpath


# ------------------------------------------------------------
