# ============================================================
# .gitignore — Proyecto Ciencia de Datos (Aguacate Prices)
# ============================================================


# ------------------------------------------------------------
# DATOS
# ------------------------------------------------------------
data/
*.csv
*.xlsx
*.xls
*.json
*.parquet
*.feather
*.h5
*.hdf5
*.pickle
*.pkl


# ------------------------------------------------------------
# MODELOS ENTRENADOS
# ------------------------------------------------------------
models/
*.joblib
*.sav
*.pt
*.pth
*.onnx


# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Entornos virtuales
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribución / empaquetado
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
MANIFEST

# Instalaciones locales de pip
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc
nosetests.xml

# mypy / linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pylint.d/

# Profiling
*.prof


# ------------------------------------------------------------
# JUPYTER NOTEBOOKS
# ------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints

# Outputs de notebooks (mantén el código, no los outputs grandes)
# Descomenta si quieres ignorar outputs embebidos:
# *.ipynb


# ------------------------------------------------------------
# VARIABLES DE ENTORNO Y SECRETOS
# ------------------------------------------------------------
.env
.env.*
*.env
!.env.example
secrets.yaml
secrets.yml
config/secrets.*
credentials.json
token.json


# ------------------------------------------------------------
# IDEs — VS CODE
# ------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace


# ------------------------------------------------------------
