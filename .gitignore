# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp


# ------------------------------------------------------------
# SISTEMA OPERATIVO — MACOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent


# ------------------------------------------------------------
# SISTEMA OPERATIVO — LINUX
# ------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ------------------------------------------------------------
# LOGS Y TEMPORALES
# ------------------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig


# ------------------------------------------------------------
